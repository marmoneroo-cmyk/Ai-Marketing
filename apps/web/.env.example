# Public base URL of the BrandPilot NestJS API (apps/api). Defaults to http://localhost:4000.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Demo mode. When "true", the data layer falls back to realistic mock data
# whenever the API is unreachable (so the dashboard renders without a backend).
# When "false" (default / production), API failures surface as real errors and
# empty responses render genuine empty states.
NEXT_PUBLIC_DEMO_MODE=false
