{
  "name": "brandpilot",
  "version": "0.0.0",
  "private": true,
  "description": "BrandPilot — Autonomous AI Marketing OS for small businesses",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @brandpilot/db generate",
    "db:migrate": "pnpm --filter @brandpilot/db migrate",
    "db:seed": "pnpm --filter @brandpilot/db seed",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.11.1"
    }
  }
}
