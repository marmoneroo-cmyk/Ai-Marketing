{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm --filter @brandpilot/web build",
    "watchPatterns": ["apps/web/**", "packages/core/**", "pnpm-lock.yaml", "railway.web.json"]
  },
  "deploy": {
    "startCommand": "pnpm --filter @brandpilot/web start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
