{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'api runs via tsx — no compile step'",
    "watchPatterns": ["apps/api/**", "packages/**", "pnpm-lock.yaml", "railway.api.json"]
  },
  "deploy": {
    "startCommand": "pnpm --filter @brandpilot/api exec tsx src/main.ts",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
