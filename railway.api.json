{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'api runs via swc-node — no compile step'"
  },
  "deploy": {
    "startCommand": "pnpm --filter @brandpilot/api exec node -r @swc-node/register src/main.ts",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
