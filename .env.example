# ─── Core ───────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── Database (PostgreSQL 16 + pgvector) ─────────────────────────────────────
DATABASE_URL=postgresql://brandpilot:brandpilot@localhost:5432/brandpilot

# ─── Redis / BullMQ ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
AUTH_SECRET=change-me-generate-a-32-byte-random-secret
# Envelope-encryption key for OAuth tokens at rest (base64, 32 bytes)
TOKEN_ENCRYPTION_KEY=change-me-base64-32-bytes

# ─── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
FAL_KEY=

# ─── Social / Integrations ───────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
# OAuth redirect + webhook URLs are DERIVED from API_URL (see connectorRouteUrl in
# @brandpilot/config) — there is no separate *_REDIRECT_URI to set. Register these
# EXACT URLs in your Meta app (must be publicly reachable in a deployed env):
#   redirect_uri : {API_URL}/connectors/meta/callback   (e.g. http://localhost:4000/connectors/meta/callback)
#   webhook      : {API_URL}/connectors/meta/webhook
# Token used to verify the Meta Graph API GET (subscribe) webhook handshake
META_VERIFY_TOKEN=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Token used to verify the WhatsApp Cloud API GET (subscribe) webhook handshake
WHATSAPP_VERIFY_TOKEN=
FIRECRAWL_API_KEY=

# ─── Payments ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email ───────────────────────────────────────────────────────────────────
# Sender identity for transactional email (e.g. password-reset links). Has a safe
# default in @brandpilot/config, so this is optional to set locally.
# The actual transactional-email provider (Resend/SES/SMTP) is a later gated integration.
EMAIL_FROM=BrandPilot <no-reply@brandpilot.app>

# ─── Object storage (S3-compatible) ──────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=brandpilot
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=
# OTLP endpoint for OpenTelemetry tracing export (e.g., http://localhost:4318)
OTEL_EXPORTER_OTLP_ENDPOINT=

# ─── Demo Mode ───────────────────────────────────────────────────────────────
# Expose fabricated data when API is unreachable (for offline testing only)
NEXT_PUBLIC_DEMO_MODE=false
